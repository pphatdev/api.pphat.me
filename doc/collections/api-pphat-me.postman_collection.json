				{
					"name": "Email",
					"item": [
						{
							"name": "Register with Email",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"info.sophat@gmail.com\",\n  \"name\": \"John Doe\",\n  \"password\": \"mypassword123\"\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": {
									"raw": "{{baseUrl}}/v1/api/auth/email/register",
									"host": ["{{baseUrl}}"],
									"path": ["v1", "api", "auth", "email", "register"]
								},
								"description": "Creates a new email account and sends a 6-digit OTP to verify the email. Password must be at least 8 characters. Returns 201 on success."
							},
							"response": []
						},
						{
							"name": "Login with Email",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"info.sophat@gmail.com\",\n  \"password\": \"mypassword123\"\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": {
									"raw": "{{baseUrl}}/v1/api/auth/email/login",
									"host": ["{{baseUrl}}"],
									"path": ["v1", "api", "auth", "email", "login"]
								},
								"description": "Authenticates a verified email account with password. Returns { token } directly."
							},
							"response": []
						},
						{
							"name": "Verify OTP",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"info.sophat@gmail.com\",\n  \"otp\": \"123456\"\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": {
									"raw": "{{baseUrl}}/v1/api/auth/email/verify",
									"host": ["{{baseUrl}}"],
									"path": ["v1", "api", "auth", "email", "verify"]
								},
								"description": "Verifies the 6-digit OTP. Returns { token } on success. The OTP is valid for 10 minutes and can only be used once."
							},
							"response": []
						}
					]
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"description": "JWT token obtained from the login callback"
