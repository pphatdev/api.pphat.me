				{
					"name": "GitHub",
					"item": [
						{
							"name": "Login with GitHub",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/v1/api/auth/github",
									"host": ["{{baseUrl}}"],
									"path": ["v1", "api", "auth", "github"]
								},
								"description": "Redirects to GitHub OAuth authorization page. Open this URL in a browser; after approving, GitHub will redirect to the callback URL with a code."
							},
							"response": []
						},
						{
							"name": "GitHub Callback",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/v1/api/auth/github/callback?code=GITHUB_CODE&state=OAUTH_STATE",
									"host": ["{{baseUrl}}"],
									"path": ["v1", "api", "auth", "github", "callback"],
									"query": [
										{ "key": "code", "value": "GITHUB_CODE", "description": "Authorization code returned by GitHub" },
										{ "key": "state", "value": "OAUTH_STATE", "description": "State value returned by GitHub (CSRF token)" }
									]
								},
								"description": "Exchanges the GitHub authorization code for a JWT. Returns { token }."
							},
							"response": []
						}
					]
				},
