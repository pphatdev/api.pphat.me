						],
						"url": {
							"raw": "{{baseUrl}}/v1/api/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "api", "auth", "me"]
						},
						"description": "Returns the currently authenticated user. Requires a valid Bearer JWT in the Authorization header."
					},
					"response": []
				}
			]
