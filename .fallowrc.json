{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/workers/*.ts",
    "scripts/*.ts"
  ],
  "ignorePatterns": [
    "**/*.generated.ts"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "off"
  }
}